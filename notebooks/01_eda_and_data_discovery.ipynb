 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# EchoChain Notebook 01: Exploratory Data Analysis & Data Discovery\n",
    "\n",
    "This notebook performs exploratory data discovery on internal ERP Bill of Materials (BOM), warranty claims datasets, user e-waste records, and external secondary marketplace listings scraped from **eBay, Facebook Marketplace, OLX, and BackMarket**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import json\n",
    "import os\n",
    "\n",
    "# 1. Load Manufacturing BOM\n",
    "bom_path = os.path.join('..', 'data', 'raw', 'manufacturing_bom.csv')\n",
    "df_bom = pd.read_csv(bom_path)\n",
    "print(f'BOM Component Records: {len(df_bom)}')\n",
    "df_bom.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2. Load Warranty Claims Dataset\n",
    "warranty_path = os.path.join('..', 'data', 'raw', 'warranty_claims.csv')\n",
    "df_warranty = pd.read_csv(warranty_path)\n",
    "print(f'Warranty Claim Records: {len(df_warranty)}')\n",
    "df_warranty.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3. Load Secondary Marketplace Listings\n",
    "listings_path = os.path.join('..', 'data', 'raw', 'marketplace_listings.json')\n",
    "with open(listings_path, 'r', encoding='utf-8') as f:\n",
    "    listings_data = json.load(f)\n",
    "df_listings = pd.DataFrame(listings_data)\n",
    "print(f'Marketplace Listings Scraped: {len(df_listings)}')\n",
    "df_listings.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4. Summary Statistics by Marketplace Platform\n",
    "df_listings.groupby('marketplace').agg(\n",
    "    total_listings=('listing_id', 'count'),
    "    avg_price=('price', 'mean'),\n",
    "    avg_seller_rating=('seller_rating', 'mean')\n",
    ")"
   ]
  }
 ],
